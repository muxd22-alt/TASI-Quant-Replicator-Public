{
  "entities": {
    "Fund": {
      "title": "Investment Fund",
      "description": "Metadata for a TASI investment fund being tracked",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "currentModelStatus": { "type": "string", "enum": ["initial", "evolving", "optimized"] },
        "benchmark": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "Report": {
      "title": "Quarterly Report",
      "description": "Extracted data and model state from a PDF report",
      "type": "object",
      "properties": {
        "fundId": { "type": "string" },
        "quarter": { "type": "string", "description": "e.g., Q1-2024" },
        "holdings": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "ticker": { "type": "string" },
              "weight": { "type": "number" },
              "sentiment": { "type": "string" }
            }
          }
        },
        "totalAssets": { "type": "string" },
        "aiInsights": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fundId", "quarter", "status"]
    },
    "Ticker": {
      "title": "TASI Ticker",
      "description": "Historical data tracking for individual stocks",
      "type": "object",
      "properties": {
        "symbol": { "type": "string" },
        "name": { "type": "string" },
        "lastPrice": { "type": "number" },
        "history": {
          "type": "array",
          "items": { "type": "object" }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["symbol"]
    }
  },
  "firestore": {
    "/funds/{fundId}": {
      "schema": "Fund",
      "description": "Root collection for fund metadata"
    },
    "/funds/{fundId}/reports/{reportId}": {
      "schema": "Report",
      "description": "Quarterly reports for a specific fund"
    },
    "/tickers/{symbol}": {
      "schema": "Ticker",
      "description": "Global ticker registry for automated tracking"
    }
  }
}
