rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Constants & Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validation Helpers
    function isValidFund(data) {
      return data.keys().hasAll(['name']) 
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && (!('benchmark' in data) || (data.benchmark is string && data.benchmark.size() <= 100));
    }

    function isValidReport(data) {
      return data.keys().hasAll(['fundId', 'quarter', 'status'])
        && data.fundId is string && isValidId(data.fundId)
        && data.quarter is string && data.quarter.size() <= 20
        && data.status in ['pending', 'completed', 'failed'];
    }

    function isValidTicker(data) {
      return data.keys().hasAll(['symbol'])
        && data.symbol is string && data.symbol.size() <= 10;
    }

    // Match Groups
    match /funds/{fundId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(fundId) && isValidFund(incoming());
      allow update: if isSignedIn() && isValidFund(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'benchmark', 'currentModelStatus']);
      
      match /reports/{reportId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if isSignedIn() && isValidId(reportId) && isValidReport(incoming());
        allow update: if isSignedIn() && isValidReport(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'holdings', 'aiInsights', 'totalAssets']);
      }
    }

    match /tickers/{symbol} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow write: if isSignedIn() && isValidId(symbol) && isValidTicker(incoming());
    }
  }
}
